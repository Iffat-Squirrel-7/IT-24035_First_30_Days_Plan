class Person {

    String name;
    int age;
    Person(String name, int age) {
        this.name = name;
        this.age = age;
    }

    void show() {
        System.out.println("Name: " + name);
        System.out.println("Age: " + age);
    }
}

public class Main {
    public static void main(String[] args) {

        Person p1 = new Person("Iffat", 22);

        p1.show();
    }
}
