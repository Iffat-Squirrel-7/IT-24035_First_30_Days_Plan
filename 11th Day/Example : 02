import java.util.Queue;
import java.util.LinkedList;

class Student {
    String name;

    
    Student(String name) {
        this.name = name;
    }

    void showStudent() {
        System.out.println("Student Name: " + name);
    }
}

public class Main {
    public static void main(String[] args) {

        
        Queue<Student> students = new LinkedList<>();

        
        students.add(new Student("Rahim"));
        students.add(new Student("Karim"));
        students.add(new Student("Nila"));

        
        while (!students.isEmpty()) {
            Student s = students.poll();
            s.showStudent();
        }
    }
}
