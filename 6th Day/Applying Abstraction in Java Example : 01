abstract class Car {

    
    abstract void start();

    
    void stop() {
        System.out.println("Car stopped");
    }
}

class BMW extends Car {
    
    void start() {
        System.out.println("BMW starts with button");
    }
}

class Tesla extends Car {
    
    void start() {
        System.out.println("Tesla starts silently");
    }
}

public class Main {
    public static void main(String[] args) {

        Car c1 = new BMW();
        Car c2 = new Tesla();

        c1.start();
        c1.stop();

        c2.start();
        c2.stop();
    }
}
