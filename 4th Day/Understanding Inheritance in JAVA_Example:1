class Vehicle {

    String brand;

    void showBrand() {
        System.out.println("Brand: " + brand);
    }
}

class Car extends Vehicle {

    int speed;

    void showSpeed() {
        System.out.println("Speed: " + speed);
    }
}

public class Main {
    public static void main(String[] args) {

        Car c = new Car();

        c.brand = "Toyota";  
        c.speed = 120;       

        c.showBrand();  
        c.showSpeed();  
    }
}
