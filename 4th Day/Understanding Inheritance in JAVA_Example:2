class Person {

    String name;

    void displayName() {
        System.out.println("Name: " + name);
    }
}

class Student extends Person {

    int id;

    void showId() {
        System.out.println("ID: " + id);
    }
}

public class Main {
    public static void main(String[] args) {

        Student s = new Student();

        s.name = "Iffat"; 
        s.id = 24035;       

        s.displayName(); 
        s.showId();      
    }
}
