class Car {

    String carName = "BMW";

    
    class Engine {
        void showEngine() {
            System.out.println(carName + " has a powerful engine");
        }
    }
}

public class Main {
    public static void main(String[] args) {

        Car car = new Car();

        
        Car.Engine engine = car.new Engine();

        engine.showEngine();
    }
}
