import java.io.FileInputStream;
import java.io.FileOutputStream;

public class CarFileStream {
    public static void main(String[] args) {

        try {
            
            FileOutputStream fout = new FileOutputStream("car.txt");

            String carData = "Car Name: Tesla\nModel: Model S";

            byte[] data = carData.getBytes();

            fout.write(data);
            fout.close();

            System.out.println("Car data saved successfully!");

            
            FileInputStream fin = new FileInputStream("car.txt");

            int i;

            System.out.println("\nReading Car File:");

            while ((i = fin.read()) != -1) {
                System.out.print((char) i);
            }

            fin.close();

        } catch (Exception e) {
            System.out.println(e);
        }
    }
}
