import java.io.*;

public class CarByteStream {
    public static void main(String[] args) {

        try {
            
            FileOutputStream fout = new FileOutputStream("car.txt");

            String car = "Car Name: BMW\nModel: X5";

            byte b[] = car.getBytes();

            fout.write(b);
            fout.close();

            System.out.println("Car data written successfully!");

            
            FileInputStream fin = new FileInputStream("car.txt");

            int i;
            System.out.println("\nReading Car Data:");

            while ((i = fin.read()) != -1) {
                System.out.print((char) i);
            }

            fin.close();

        } catch (Exception e) {
            System.out.println(e);
        }
    }
}
